# Ручная выдача через AmneziaVPN (рекомендуется)
# Админ создаёт клиента в AmneziaVPN на VPS → Поделиться → vpn://
# → /admin_approve <order_id> → вставить ключ
VPN_PROVISIONER=manual

# Автовыдача через bivlked AWG (опционально)
# VPN_PROVISIONER=ssh
# SSH_HOST=your-vps-ip
# SSH_PORT=22
# SSH_USER=root
# SSH_PASSWORD=
# SSH_KEY_PATH=
# SSH_ADD_CLIENT_SCRIPT=/root/awg/manage_amneziawg.sh
# SSH_ADD_CLIENT_ARGS=add
# SSH_REMOVE_CLIENT_ARGS=remove
# SSH_CONFIG_DIR=/root/awg
# SSH_INVOKE_WITH_BASH=true
# SSH_AWG_SERVER_CONF=/etc/amnezia/amneziawg/awg0.conf
# SSH_MERGE_SERVER_AWG_PARAMS=false
# SSH_AWG_PERSISTENT_KEEPALIVE=25
# VPN_SKIP_AWG_ENRICHMENT=true

AMNEZIA_API_URL=
AMNEZIA_API_KEY=
AMNEZIA_HOST=
AMNEZIA_DNS1=1.1.1.1
AMNEZIA_DNS2=1.0.0.1
AMNEZIA_DESCRIPTION=VPN
AMNEZIA_MTU=1280
AMNEZIA_EXPECTED_PORT=0

REFERRAL_BONUS_DAYS=3
TRIAL_DAYS=7

EXPIRY_CHECK_HOURS=6
EXPIRE_POLL_MINUTES=60
RETRY_FULFILLMENT_MINUTES=10

ADMIN_SUBSCRIPTION_REPORT_ENABLED=true
ADMIN_SUBSCRIPTION_REPORT_HOURS=12
