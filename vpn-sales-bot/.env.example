# Telegram ID админов через запятую
ADMIN_IDS=123456789

PAYMENTS_ENABLED=true
MINI_APP_URL=
STARS_BUY_BOT_URL=https://t.me/StarsFreeRuBot
HTTP_HOST=0.0.0.0
